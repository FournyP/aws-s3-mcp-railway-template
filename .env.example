# Gateway service ----------------------------------------------------------
# Required. Comma-separated list of allowed bearer tokens. Clients must send:
#   Authorization: Bearer <one of these keys>
# Allowed characters per key: A-Z a-z 0-9 . _ ~ + / = -
API_KEYS=

# Optional. Defaults match the template's internal wiring; only override if
# you rename the mcp service.
# MCP_HOST=mcp.railway.internal
# MCP_PORT=3000

# MCP service --------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Comma-separated allowlist of bucket names the MCP server may access.
# If unset, no buckets are exposed.
S3_BUCKETS=
S3_MAX_BUCKETS=5
